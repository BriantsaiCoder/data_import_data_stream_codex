<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
	<!-- Development 環境設定 -->
	<add key="DevHost" value="localhost" />
	<add key="DevUserName" value="root" />
	<add key="DevPassword" value="root" />
	<add key="DevPort" value="3306" />
	<add key="DevDatabase" value="dct" />
	<!-- Production 環境設定 -->
	<add key="ProdHost" value="10.16.92.67" />
	<add key="ProdUserName" value="5910" />
	<add key="ProdPassword" value="TID_5910!" />
	<add key="ProdPort" value="3306" />
	<add key="ProdDatabase" value="dct" />
	<!-- 影子驗證(DRY-RUN):true 時只解析比對,不真正寫入 DB / 搬刪 FTP 檔 / 寄信(.NET 8 cutover 影子試跑用)。預設 false。缺此 key 亦 fail-safe OFF。 -->
	<add key="DryRun" value="false" />
	<!-- 匯入檔案來源:
	     Ftp   = 由 FTP 下載並匯入，維持既有行為。預設值。
	     Local = 由 LocalImportRoot 指定的本機目錄讀檔匯入。 -->
	<add key="ImportSource" value="Ftp" />
	<!-- Local 模式的資料根目錄。ImportSource=Local 時必填。
	     目錄結構需鏡像 FTP 子路徑，例如 Data_Cloud_CSV、Tester_Status、TSMC_DATA\IEDA。 -->
	<add key="LocalImportRoot" value="D:\DCT_LocalImport" />
	<!-- Local 匯入成功後處理方式:
	     Delete  = 成功後刪除來源檔，對齊 FTP 模式。預設值。
	     Archive = 成功後搬到 LocalImportRoot\Imported\原相對路徑，保留追溯。 -->
	<add key="LocalSuccessAction" value="Delete" />
  </appSettings>
  <connectionStrings>
    <add name="FtpIp" connectionString="10.16.92.67" />
    <add name="FtpUser" connectionString="tid" />
    <add name="FtpPassword" connectionString="5900" />
  </connectionStrings>
</configuration>
